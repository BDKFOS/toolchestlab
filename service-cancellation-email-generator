<script>
async function generateEmail(){
const context=document.getElementById("context").value;
const tone=document.getElementById("tone").value;
const name=document.getElementById("name").value;
const result=document.getElementById("result");

if(!context.trim()){
result.innerText="Please describe the service cancellation.";
return;
}

result.innerText="Generating...";

const prompt=`Write a ${tone.toLowerCase()} service cancellation email.

Situation:
${context}

Requirements:
- Include a subject line
- Clearly state the cancellation request
- Keep the tone professional and direct
- Ask for confirmation if appropriate
- Keep it concise
- End appropriately

Signed:
${name || "Sender"}`;

try{
const response=await fetch("/api/generate",{
method:"POST",
headers:{"Content-Type":"application/json"},
body:JSON.stringify({prompt})
});
const data=await response.json();
result.innerText=data.message || "Something went wrong. Please try again.";
}catch(error){
result.innerText="Error generating email. Please try again.";
}
}

function copyResult(){
const text=document.getElementById("result").innerText;
navigator.clipboard.writeText(text).then(()=>{alert("Copied to clipboard!");});
}
</script>

